font-family = Liga SFMono Nerd Font Regular
font-size = 14

mouse-hide-while-typing = true

adjust-cell-height = 80%

window-save-state = always

window-colorspace = "display-p3"
window-padding-x = 24
window-padding-y = 24
window-padding-balance = true

window-height = 30
window-width = 120

macos-titlebar-style = tabs

theme = Nord Wave

# Background
background-opacity = 0.9
background-blur = true


# keybinds
keybind = ctrl+a>shift+\=new_split:right
keybind = ctrl+a>-=new_split:down
keybind = super+left=goto_split:left
keybind = super+right=goto_split:right
keybind = super+up=goto_split:top
keybind = super+down=goto_split:bottom

keybind = super+r=reload_config
keybind = shift+enter=text:\x1b\r
