// Zed settings
{
  "title_bar": {
    "show_project_items": false,
    "show_branch_icon": false,
    "show_onboarding_banner": false,
    "show_user_menu": false,
    "show_branch_name": false
  },
  "toolbar": {
    "quick_actions": false
  },
  "status_bar": {
    "experimental.show": false
  },
  "edit_predictions": {
    "provider": "zed"
  },
  "buffer_font_weight": 300.0,
  "gutter": {
    "min_line_number_digits": 0,
    "line_numbers": true
  },
  "soft_wrap": "preferred_line_length",
  "preferred_line_length": 120,
  "show_wrap_guides": false,
  "scrollbar": {
    "show": "auto"
  },
  "icon_theme": "Material Icon Theme",
  "base_keymap": "VSCode",
  "agent": {
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-5"
    }
  },
  "theme": "Min Dark (Solid)",
  "buffer_font_size": 13.0,
  "buffer_line_height": {
    "custom": 3.0
  },
  "buffer_font_family": "Liga SFMono Nerd Font",
  "ui_font_family": "JetBrains Mono NL",
  "ui_font_size": 16,
  "confirm_quit": false,
  "vim_mode": false,
  "relative_line_numbers": "disabled",
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "project_panel": {
    "dock": "right",
    "default_width": 400,
    "auto_reveal_entries": true,
    "auto_fold_dirs": false,
    "hide_root": true,
    "starts_open": false,
    "sticky_scroll": false,
    "entry_spacing": "comfortable",
    "indent_guides": {
      "show": "never"
    }
  },
  "outline_panel": {
    "default_width": 300,
    "indent_guides": {
      "show": "never"
    }
  },
  "file_finder": {
    "modal_max_width": "large"
  },
  "tab_bar": {
    "show": false
  },
  "indent_guides": {
    "enabled": false
  },
  "terminal": {
    "shell": {
      "program": "zsh"
    }
  },
  "lsp": {
    "biome": {
      "binary": {
        "path": "npx",
        "arguments": ["@biomejs/biome", "lsp-proxy"]
      }
    },
    "wakatime": {
      "settings": {}
    },
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": true,
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayVariableTypeHints": true,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": false,
          "includeInlayPropertyDeclarationTypeHints": true,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayEnumMemberValueHints": true
        }
      }
    }
  },
  "languages": {
    "TypeScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "@biomejs/biome",
            "format",
            "--stdin-file-path",
            "{buffer_path}"
          ]
        }
      }
    },
    "JavaScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "@biomejs/biome",
            "format",
            "--stdin-file-path",
            "{buffer_path}"
          ]
        }
      }
    },
    "JSON": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "@biomejs/biome",
            "format",
            "--stdin-file-path",
            "{buffer_path}"
          ]
        }
      }
    }
  }
}
